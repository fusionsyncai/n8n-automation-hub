# Copy to .env.local for local development. NEXT_PUBLIC_* values are inlined at
# build time, so rebuild after changing them. All values are optional; the app
# falls back to the production defaults baked into lib/site-config.ts.

# Canonical site URL. Drives metadataBase, OG/Twitter images, canonical links,
# sitemap, RSS, JSON-LD. Must be an absolute https URL in production.
NEXT_PUBLIC_SITE_URL=https://workflow.fusionsync.ai

# Parent agency (FusionSync AI).
NEXT_PUBLIC_PARENT_URL=https://fusionsync.ai
NEXT_PUBLIC_AGENCY_URL=https://fusionsync.ai
NEXT_PUBLIC_AGENCY_SERVICES_URL=https://fusionsync.ai/services
NEXT_PUBLIC_AGENCY_CONTACT_URL=https://fusionsync.ai/contact
NEXT_PUBLIC_AGENCY_BOOK_CALL_URL=https://cal.com/fusionsyncai/n8n-hub-call-booking

# Legal pages (live on the agency domain).
NEXT_PUBLIC_PRIVACY_URL=https://fusionsync.ai/privacy
NEXT_PUBLIC_TERMS_URL=https://fusionsync.ai/terms
